# ============================================================
# Banking MCP Server — Environment Variables
# ============================================================

# ----- Среда -----
ENV=dev
LOG_LEVEL=INFO

# ----- Server -----
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
MCP_TRANSPORT=http

# ----- API Key (за REST endpoints) -----
# Генерирай с: python -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=change-me-in-production

# ----- Dashboard (Streamlit) -----
DASHBOARD_PORT=8501
DASHBOARD_URL=http://localhost:8501
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me

# ----- JWT -----
# Генерирай с: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-key-change-me-32-bytes-min
JWT_ALGORITHM=HS256

# ----- Audit logging -----
AUDIT_LOG_PATH=./logs/audit.log
AUDIT_LOG_RETENTION_DAYS=30
AUDIT_ENABLED=true

# ----- Bank info DB -----
# SQLite по подразбиране; задайте ORACLE_DSN за Oracle
BANK_INFO_DB_PATH=./data/bank_info.db

# ----- Oracle DB (опционално) -----
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=

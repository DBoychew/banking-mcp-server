# ============================================================
# Banking MCP Server - Environment Variables
# ============================================================

# ----- Environment -----
ENV=
LOG_LEVEL=

# ----- Server -----
SERVER_HOST=
SERVER_PORT=
MCP_TRANSPORT=
MCP_HTTP_PATH=
MCP_STATELESS_HTTP=

# ----- Audit logging -----
AUDIT_LOG_PATH=
AUDIT_LOG_RETENTION_DAYS=
AUDIT_ENABLED=

# ----- Data directory (where db_config.json and SQLite files live) -----
DATA_DIR=

# ----- Oracle DB (primary masked schema) -----
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_DSN=
ORACLE_SCHEMA=

# ============================================================
# Multi-DB support (optional)
#
# Connections are configured at runtime via add_connection() or by editing
# data/db_config.json. DSN strings support ${VAR} env-var substitution so
# credentials live here, not in the JSON file.
# ============================================================

# ----- PostgreSQL example -----
# PG_DSN=postgresql://user:pass@host:5432/db
# Then add via: tools.execute_sql_query(...) using connection name from db_config.json

# ----- MySQL / MariaDB example -----
# MYSQL_DSN=mysql://user:pass@host:3306/db

# ----- DuckDB example -----
# DUCKDB_DSN=duckdb:///./data/analytics.duckdb

# ----- ClickHouse example -----
# CLICKHOUSE_DSN=clickhouse://default:@host:8123/default
